# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=3000

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=https://cube-game-production-9d45.up.railway.app,http://localhost:3000

# Admin secret for /stats and /audit endpoints
ADMIN_SECRET=your-strong-secret-here

# Firebase (inject to client via /config endpoint - never expose in client JS)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=your-app-id
