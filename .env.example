# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=3000

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=https://cube-game-production-e946.up.railway.app/http://localhost:3000

# Admin secret for /stats and /audit endpoints
ADMIN_SECRET=your-strong-secret-here

# Firebase (inject to client via /config endpoint - never expose in client JS)
FIREBASE_API_KEY="AIzaSyC_gTL3m6Snz9bUcTIr1teBWQG9KsG-0ds",
FIREBASE_AUTH_DOMAIN="cube-game-515d7.firebaseapp.com"
FIREBASE_PROJECT_ID="cube-game-515d7"
FIREBASE_APP_ID= "1:232796990803:web:d66c07add2373217a545a6"

# Firebase Admin SDK — powers /api/leaderboard and /api/score (server-side only).
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key.
# Paste the ENTIRE downloaded JSON file as a single-line string here.
# Leave unset and the leaderboard routes just return 503 — nothing else breaks.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...", ...}
